# Server-side only (used by Vercel serverless function / Vite dev proxy)
OPENAI_API_KEY=your_openai_api_key_here

# Supabase (client-side — VITE_ prefix required)
# Get these from: https://supabase.com/dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase Service Role Key (server-side only — for plan updates after payment)
# Get from: Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Razorpay (server-side — for payment processing)
# Get from: https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Sentry (optional — error monitoring)
# Get from: https://sentry.io → Settings → Projects → Client Keys (DSN)
# Leave blank to disable Sentry
VITE_SENTRY_DSN=

# App version (optional — shown in Sentry releases, set by CI)
VITE_APP_VERSION=1.0.0

# Production URL — REQUIRED for Google OAuth to redirect correctly after login
# Set in Vercel: Settings → Environment Variables → VITE_APP_URL
VITE_APP_URL=https://gfg-hack-1-i3sh.vercel.app

# Allowed CORS origin for /api/chat (optional, defaults to *)
ALLOWED_ORIGIN=https://gfg-hack-1-i3sh.vercel.app
